{{!
    @template auth_coursetransit/settings_card

    CourseTransit settings dashboard card.

    Example context (json):
    {
        "description": "Connect WordPress websites with Moodle.",
        "setupincomplete": true,
        "setupwarningtitle": "Setup incomplete",
        "setupwarningdesc": "Complete the setup wizard.",
        "wizardurl": "http://example.com/auth/coursetransit/wizard.php",
        "wizardbutton": "Launch Setup Wizard",

        "setupcomplete": false,

        "dashboardurl": "http://example.com/auth/coursetransit/index.php",
        "dashboardbutton": "Open Dashboard",

        "setupcompletetitle": "CourseTransit configured",
        "setupcompletedesc": "Platform ready to use."
    }
}}

<div class="auth-coursetransit-settings-card">

    <div class="card border-0 shadow-sm">

        <div class="card-body p-4">

            <div class="small text-uppercase font-weight-bold text-primary mb-2">
                Authentication & Integration Platform
            </div>

            <p class="text-muted mb-4"
               style="line-height: 1.8;">
                {{description}}
            </p>

            {{#setupincomplete}}

                <div class="alert alert-warning mb-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center">

                    <div class="pr-md-3">

                        <strong>{{setupwarningtitle}}</strong>

                        <div class="mt-1">
                            {{setupwarningdesc}}
                        </div>

                    </div>

                    <div class="mt-3 mt-md-0">

                        <a href="{{wizardurl}}"
                        class="btn btn-warning font-weight-bold">

                            {{wizardbutton}}

                        </a>

                    </div>

                </div>

            {{/setupincomplete}}

            {{#setupcomplete}}

                <div class="alert alert-success mb-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center">

                    <div class="pr-md-3">

                        <strong>{{setupcompletetitle}}</strong>

                        <div class="mt-1">
                            {{setupcompletedesc}}
                        </div>

                    </div>

                    <div class="mt-3 mt-md-0">

                        <a href="{{dashboardurl}}"
                        class="btn btn-success font-weight-bold">

                            {{dashboardbutton}}

                        </a>

                    </div>

                </div>

            {{/setupcomplete}}

        </div>

    </div>

</div>