{{!
    @template auth_coursetransit/sites

    Example context (json):
    {
        "formhtml": "<form action=\"#\">Add Site Form</form>",
        "sites": [
            {
                "id": 1,
                "name": "Test Site",
                "domain": "example.com",
                "token": "abc123xyz",
                "configaction": "<a href=\"#\">Configure</a>",
                "deleteaction": "<button>Delete</button>"
            }
        ]
    }
}}

<div class="card">
    <div class="card-body">

        <h3 class="card-title">
            {{#str}}sites_title, auth_coursetransit{{/str}}
        </h3>

        {{{formhtml}}}

        <table class="table fullwidth">
            <thead>
                <tr>
                    <th>Site Name</th>
                    <th>Domain</th>
                    <th>Token</th>
                    <th>Settings</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {{#sites}}
                <tr>
                    <td><strong>{{name}}</strong></td>
                    <td>
                        <a href="https://{{domain}}" target="_blank">
                            {{domain}}
                        </a>
                    </td>
                    <td><code>{{token}}</code></td>
                    <td>
                        {{{configaction}}}
                    </td>
                    <td class="text-center">
                        {{{deleteaction}}}
                    </td>
                </tr>
                {{/sites}}
            </tbody>
        </table>

        {{^sites}}
        <div class="alert alert-info mt-3">
            No WordPress sites registered yet.
        </div>
        {{/sites}}
    </div>
</div>
