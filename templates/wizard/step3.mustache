{{!
    @template auth_coursetransit/wizard/step4

    Example context (json):
    {
        "title": "Site Token",
        "once_label": "Shown only once",
        "description": "Copy and store this token securely.",
        "token": "abc123...",
        "important_label": "Important",
        "important_text": "If lost, you must regenerate.",
        "button": "Continue",
        "next": "#"
    }
}}

<div class="card p-4 text-center">

    {{#title}}
        <h4>{{title}}</h4>
    {{/title}}

    {{#once_label}}
    <div class="mt-3 mb-3">
        <p class="mb-1">
            <strong>{{once_label}}</strong>
        </p>

        {{#description}}
            <p class="text-muted small mb-0">
                {{description}}
            </p>
        {{/description}}
    </div>
    {{/once_label}}

    {{#token}}
    <div
        id="coursetransit-token-source"
        data-token="{{token}}"
        hidden>
    </div>

    <div class="border rounded p-3 bg-light mb-3">
        <code
            id="coursetransit-token-display"
            style="
                font-size:13px;
                color:#d63384;
                word-break:break-all;
                display:block;
            ">
        </code>
    </div>
    {{/token}}

    {{#important_text}}
    <!-- WARNING BOX -->
    <div class="alert alert-warning text-start" style="border-left:4px solid #dc3545;">
        {{#important_label}}
            <strong>⚠ {{important_label}}</strong><br>
        {{/important_label}}

        {{important_text}}
    </div>
    {{/important_text}}

    {{#next}}
    <div class="mt-3">
        <a href="{{next}}" class="btn btn-primary px-4 py-2">
            {{button}}
        </a>
    </div>
    {{/next}}

</div>